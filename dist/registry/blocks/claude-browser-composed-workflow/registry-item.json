{
  "$schema": "https://hyperframes.heygen.com/schema/registry-item.json",
  "name": "claude-browser-composed-workflow",
  "type": "hyperframes:block",
  "title": "Claude Componentized Shell Plus Browser Workflow",
  "description": "Short clips that need a full Claude shell plus a browser app while preserving the reusable sidebar, thread core, composer, and rail as independently editable child components.",
  "tags": [
    "workflow",
    "claude",
    "browser",
    "composed-shell",
    "nested-components",
    "modular-assembly",
    "mac-menu-bar"
  ],
  "author": "UI Backlot contributors",
  "license": "ISC",
  "minCliVersion": "0.6.114",
  "sourcePrompt": "Install editable UI Backlot source into a HyperFrames project; keep the copied HTML/CSS/JS editable.",
  "registryDependencies": [
    "mac-menu-bar",
    "browser-app",
    "claude-composed-app"
  ],
  "files": [
    {
      "path": "compositions/claude-browser-composed-workflow.html",
      "target": "compositions/claude-browser-composed-workflow.html",
      "type": "hyperframes:composition"
    },
    {
      "path": "runtime/backlot-component-loader.js",
      "target": "runtime/backlot-component-loader.js",
      "type": "hyperframes:asset"
    },
    {
      "path": "assets/cursors/normal-select.svg",
      "target": "assets/cursors/normal-select.svg",
      "type": "hyperframes:asset"
    }
  ],
  "dimensions": {
    "width": 1920,
    "height": 1080
  },
  "duration": 10
}
