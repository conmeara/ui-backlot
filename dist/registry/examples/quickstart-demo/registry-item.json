  "tags": [
    "starter",
    "claude",
    "browser",
    "example"
  ],
  "author": "UI Backlot contributors",
  "license": "ISC",
  "minCliVersion": "0.6.114",
  "sourcePrompt": "Start a fresh HyperFrames project from the editable UI Backlot Claude-plus-browser starter.",
