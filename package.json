{
  "name": "ui-backlot",
  "version": "1.0.0",
  "private": true,
  "description": "An open, agent-first backlot of editable app surfaces (Claude, Codex, macOS, Office, Figma, and more) for rendering scripted product-demo videos with HyperFrames instead of screen recordings.",
  "keywords": [
    "hyperframes",
    "demo-video",
    "ui-surfaces",
    "agent-workflows",
    "product-demos"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conmeara/ui-backlot.git"
  },
  "homepage": "https://github.com/conmeara/ui-backlot#readme",
  "bugs": {
    "url": "https://github.com/conmeara/ui-backlot/issues"
  },
  "license": "ISC",
  "author": "UI Backlot contributors",
  "engines": {
    "node": ">=22"
  },
  "type": "commonjs",
  "scripts": {
    "capture:hf": "npx hyperframes capture",
    "capture:web": "node tools/capture-web-ui.mjs",
    "capture:claude-composed-app": "node tools/capture-web-ui.mjs \"file://$PWD/compositions/claude-composed-app.html?capture=hero\" --slug surface-claude-composed-app --selector '#claude-composed-app' --viewport 1540x980",
    "capture:claude-composed-app-chat": "node tools/capture-web-ui.mjs \"file://$PWD/compositions/claude-composed-app.html?capture=hero&page=chat\" --slug surface-claude-composed-app-chat --selector '#claude-composed-app' --viewport 1540x980",
    "capture:claude-composed-app-code": "node tools/capture-web-ui.mjs \"file://$PWD/compositions/claude-composed-app.html?capture=hero&page=code\" --slug surface-claude-composed-app-code --selector '#claude-composed-app' --viewport 1540x980",
    "capture:claude-composed-app-dark": "node tools/capture-web-ui.mjs \"file://$PWD/compositions/claude-composed-app.html?capture=hero\" --slug surface-claude-composed-app-dark --selector '#claude-composed-app' --viewport 1540x980 --root-class theme-dark",
    "capture:claude-composed-app-chat-dark": "node tools/capture-web-ui.mjs \"file://$PWD/compositions/claude-composed-app.html?capture=hero&page=chat\" --slug surface-claude-composed-app-chat-dark --selector '#claude-composed-app' --viewport 1540x980 --root-class theme-dark",
    "capture:claude-chat-pane": "node tools/capture-web-ui.mjs compositions/claude-chat-pane.html --slug surface-claude-chat-pane --selector '.claude-chat-pane-window' --viewport 1220x940",
    "capture:claude-sidebar": "node tools/capture-web-ui.mjs compositions/claude-sidebar.html --slug surface-claude-sidebar --selector '.claude-sidebar-stage' --viewport 480x940",
    "capture:claude-agent-rail": "node tools/capture-web-ui.mjs compositions/claude-agent-rail.html --slug surface-claude-agent-rail --selector '.claude-agent-rail-stage' --viewport 520x980",
    "capture:claude-response-mark": "node tools/capture-web-ui.mjs compositions/claude-response-mark.html --slug surface-claude-response-mark --selector '.claude-response-mark-stage' --viewport 240x240 --scale 2",
    "capture:claude-composer": "node tools/capture-web-ui.mjs compositions/claude-composer.html --slug surface-claude-composer --selector '.claude-composer-stage' --viewport 1000x320",
    "capture:claude-home": "node tools/capture-web-ui.mjs compositions/claude-home.html --slug surface-claude-home --selector '.claude-home-window' --viewport 1100x840",
    "capture:claude-thread-core": "node tools/capture-web-ui.mjs compositions/claude-thread-core.html --slug surface-claude-thread-core --selector '.claude-thread-core-stage' --viewport 1120x980",
    "capture:claude-thread-core-dark": "node tools/capture-web-ui.mjs compositions/claude-thread-core.html --slug surface-claude-thread-core-dark --selector '.claude-thread-core-stage' --viewport 1120x980 --root-class theme-dark",
    "capture:codex-thread-core": "node tools/capture-web-ui.mjs compositions/codex-thread-core.html --slug surface-codex-thread-core --selector '#codex-thread-core' --viewport 1080x920",
    "capture:codex-thread-core-dark": "node tools/capture-web-ui.mjs compositions/codex-thread-core.html --slug surface-codex-thread-core-dark --selector '#codex-thread-core' --viewport 1080x920 --root-class theme-dark",
    "capture:claude-code-terminal-session": "node tools/capture-web-ui.mjs compositions/claude-code-terminal-session.html --slug surface-claude-code-terminal-session --selector '.claude-code-terminal-session-window' --viewport 780x880",
    "capture:claude-attachment-draft": "node tools/capture-web-ui.mjs compositions/claude-attachment-draft.html --slug surface-claude-attachment-draft --selector '.claude-attachment-window' --viewport 1280x860",
    "capture:claude-tool-result": "node tools/capture-web-ui.mjs compositions/claude-tool-result.html --slug surface-claude-tool-result --selector '.claude-tool-window' --viewport 1280x860",
    "capture:claude-launch-browser-workflow-prompt": "node tools/capture-web-ui.mjs \"file://$PWD/compositions/claude-launch-browser-workflow.html?capture=prompt\" --slug surface-claude-launch-browser-prompt-workflow --selector '.launch-browser-workflow-stage' --viewport 1960x1120",
    "capture:codex-app": "node tools/capture-web-ui.mjs compositions/codex-app.html --slug surface-codex-app --selector '.codex-app-window' --viewport 1380x900",
    "capture:codex-app-dark": "node tools/capture-web-ui.mjs compositions/codex-app.html --slug surface-codex-app-dark --selector '.codex-app-window' --viewport 1380x900 --root-class theme-dark",
    "capture:slack-app": "node tools/capture-web-ui.mjs compositions/slack-app.html --slug surface-slack-app --selector '.slack-app-window' --viewport 1560x980",
    "capture:finder-window": "node tools/capture-web-ui.mjs compositions/finder-window.html --slug surface-finder-window-component --selector '.finder-window' --viewport 1000x520 --scale 2",
    "capture:finder-window-dark": "node tools/capture-web-ui.mjs compositions/finder-window.html --slug surface-finder-window-dark --selector '.finder-window' --viewport 1000x520 --scale 2 --root-class theme-dark",
    "capture:codex-terminal": "node tools/capture-web-ui.mjs compositions/codex-terminal.html --slug surface-codex-terminal --selector '.terminal-window' --viewport 1240x940",
    "capture:word-editor": "node tools/capture-web-ui.mjs compositions/word-editor.html --slug surface-word-editor --selector '.word-window' --viewport 1400x880",
    "capture:excel-workbook": "node tools/capture-web-ui.mjs compositions/excel-workbook.html --slug surface-excel-workbook --selector '.excel-window' --viewport 1400x880",
    "capture:figma-editor": "node tools/capture-web-ui.mjs compositions/figma-editor.html --slug surface-figma-editor --selector '.figma-window' --viewport 1500x960",
    "capture:figma-editor-dark": "node tools/capture-web-ui.mjs compositions/figma-editor.html --slug surface-figma-editor-dark --selector '.figma-window' --viewport 1500x960 --root-class theme-dark",
    "capture:figma-onboarding-editor": "node tools/capture-web-ui.mjs \"file://$PWD/compositions/figma-editor.html?page=onboarding\" --slug surface-figma-onboarding-editor --selector '.figma-onboarding-window' --viewport 1220x860",
    "capture:premiere-editor": "node tools/capture-web-ui.mjs compositions/premiere-editor.html --slug surface-premiere-editor --selector '.premiere-window' --viewport 1500x960",
    "capture:presentation-editor": "node tools/capture-web-ui.mjs compositions/presentation-editor.html --slug surface-presentation-editor --selector '.presentation-editor-surface' --viewport 940x540 --scale 2",
    "capture:browser-app": "node tools/capture-web-ui.mjs compositions/browser-app.html --slug surface-browser-app --selector '.browser-window'",
    "capture:browser-app-dark": "node tools/capture-web-ui.mjs compositions/browser-app.html --slug surface-browser-app-dark --selector '.browser-window' --root-class theme-dark",
    "capture:calendar": "node tools/capture-web-ui.mjs compositions/calendar-app.html --slug surface-calendar-app --selector '.calendar-window'",
    "capture:calendar-app-dark": "node tools/capture-web-ui.mjs compositions/calendar-app.html --slug surface-calendar-app-dark --selector '.calendar-window' --root-class theme-dark",
    "capture:mac-menu-bar": "node tools/capture-web-ui.mjs compositions/mac-menu-bar.html --slug surface-mac-menu-bar --selector '.mac-menu-bar-stage' --viewport 1960x90",
    "capture:mac-menu-bar-dark": "node tools/capture-web-ui.mjs compositions/mac-menu-bar.html --slug surface-mac-menu-bar-dark --selector '.mac-menu-bar-stage' --viewport 1960x90 --root-class theme-dark",
    "capture:mac-dock": "node tools/capture-web-ui.mjs compositions/mac-dock.html --slug surface-mac-dock --selector '#mac-dock-surface' --viewport 900x200 --scale 2",
    "capture:quickstart-demo": "node tools/capture-web-ui.mjs \"file://$PWD/examples/quickstart-demo.html?capture=hero\" --slug example-quickstart-demo --selector '.quickstart-stage' --viewport 1920x1080",
    "compare:finder": "tools/make-comparison-sheet.sh captures/finder-launch-deck/window.png captures/surface-finder-window/target.png snapshots/finder-source-vs-surface.jpg 'REFERENCE - Finder Launch Deck window capture' 'PROTOTYPE - Editable Finder HTML surface'",
    "compare:finder-window": "tools/make-comparison-sheet.sh captures/finder-launch-deck/window.png captures/surface-finder-window-component/target.png snapshots/finder-source-vs-component.jpg 'REFERENCE - Finder Launch Deck window capture' 'COMPONENT - Finder HyperFrames subcomposition'",
    "compare:sheets": "tools/make-comparison-sheet.sh",
    "reference:capture": "node tools/capture-live-reference.mjs",
    "reference:import": "node tools/import-reference.mjs",
    "fidelity:score": "node tools/fidelity-score.mjs",
    "icons:find": "node tools/find-icon.mjs",
    "fidelity:trend": "node tools/fidelity-trend.mjs",
    "inventory:generate": "node tools/generate-surface-inventory.mjs",
    "inventory:refresh": "node tools/generate-surface-inventory.mjs --refresh-captures",
    "catalog:generate": "node tools/generate-public-catalog.mjs",
    "registry:check": "node tools/check-surface-registry.mjs",
    "icons:check": "node tools/sync-inline-icons.mjs --check",
    "icons:sync": "node tools/sync-inline-icons.mjs --write",
    "registry:check:captures": "node tools/check-surface-registry.mjs --require-captures",
    "hf:lint": "npx hyperframes lint --verbose",
    "hf:lint:check": "node tools/check-lint-baseline.mjs",
    "hf:validate": "npx hyperframes validate --no-contrast",
    "hf:inspect": "npx hyperframes inspect --samples 9 --json",
    "hf:snapshot": "npx hyperframes snapshot . --at=1,3,5.4,7.8,10.1,12.6,15 --describe=false",
    "hf:render": "npx hyperframes render --quality draft --output renders/claude-keynote-workflow-draft.mp4",
    "example:quickstart:render": "npx hyperframes render --composition examples/quickstart-demo.html --quality draft --output renders/quickstart-demo.mp4",
    "open-source:check": "npm run catalog:generate && npm run registry:check && npm run registry:hf:check && npm run hf:lint:check && npm run hf:validate && npm run hf:inspect",
    "compare:page": "node tools/build-compare-page.mjs",
    "gallery:page": "node tools/build-gallery-page.mjs",
    "review": "npm run compare:page && npm run gallery:page && python3 -m http.server 4173",
    "registry:hf:generate": "node tools/generate-hyperframes-registry.mjs",
    "registry:hf:check": "node tools/check-hyperframes-registry.mjs",
    "pages:catalog": "node tools/build-pages-catalog.mjs",
    "capture:claude-cinematic": "node tools/capture-web-ui.mjs \"file://$PWD/compositions/claude-cinematic.html?capture=hero\" --slug surface-claude-cinematic --selector '.claude-cinematic-frame' --viewport 1920x1080",
    "capture:claude-cinematic-prompt": "node tools/capture-web-ui.mjs \"file://$PWD/compositions/claude-cinematic.html?capture=hero&beat=prompt\" --slug surface-claude-cinematic-prompt --selector '.claude-cinematic-frame' --viewport 1920x1080",
    "capture:claude-cinematic-complete": "node tools/capture-web-ui.mjs \"file://$PWD/compositions/claude-cinematic.html?capture=hero&beat=complete\" --slug surface-claude-cinematic-complete --selector '.claude-cinematic-frame' --viewport 1920x1080",
    "capture:claude-cinematic-dark": "node tools/capture-web-ui.mjs \"file://$PWD/compositions/claude-cinematic.html?capture=hero&theme=dark\" --slug surface-claude-cinematic-dark --selector '.claude-cinematic-frame' --viewport 1920x1080",
    "wallpapers:assets": "node tools/wallpapers/build-wallpaper-assets.mjs",
    "wallpapers:build": "node tools/wallpapers/build-wallpaper-surface.mjs",
    "capture:mac-wallpaper": "node tools/capture-web-ui.mjs \"file://$PWD/compositions/mac-wallpaper.html?wallpaper=sonoma\" --slug surface-mac-wallpaper --selector '#mac-wallpaper-surface' --viewport 1920x1080",
    "wallpapers:gallery": "node tools/wallpapers/build-wallpaper-gallery.mjs"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.496",
    "odiff-bin": "^4.3.8",
    "playwright": "^1.61.0"
  },
  "directories": {
    "doc": "docs"
  }
}
