{
  "$schema": "https://hyperframes.heygen.com/schema/registry-item.json",
  "name": "claude-finder-thread-workflow",
  "type": "hyperframes:block",
  "title": "Claude Working Thread Plus Finder Workflow",
  "description": "Short file/folder workflow clips that need the refined Claude working thread with Finder context, without browser, PowerPoint, attachment draft emphasis, or the full desktop lab.",
  "tags": [
    "workflow",
    "claude",
    "finder",
    "files",
    "working-thread",
    "modular-assembly",
    "mac-menu-bar"
  ],
  "author": "UI Backlot contributors",
  "license": "ISC",
  "minCliVersion": "0.6.114",
  "sourcePrompt": "Install editable UI Backlot source into a HyperFrames project; keep the copied HTML/CSS/JS editable.",
  "registryDependencies": [
    "mac-menu-bar",
    "finder-window",
    "claude-app"
  ],
  "files": [
    {
      "path": "compositions/claude-finder-workflow.html",
      "target": "compositions/claude-finder-workflow.html",
      "type": "hyperframes:composition"
    },
    {
      "path": "runtime/backlot-component-loader.js",
      "target": "runtime/backlot-component-loader.js",
      "type": "hyperframes:asset"
    },
    {
      "path": "assets/cursors/normal-select.svg",
      "target": "assets/cursors/normal-select.svg",
      "type": "hyperframes:asset"
    }
  ],
  "dimensions": {
    "width": 1920,
    "height": 1080
  },
  "duration": 10
}
