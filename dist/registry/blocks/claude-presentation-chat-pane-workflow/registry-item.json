  "tags": [
    "workflow",
    "claude",
    "powerpoint",
    "presentation",
    "office",
    "chat-pane",
    "modular-assembly"
  ],
  "author": "UI Backlot contributors",
  "license": "ISC",
  "minCliVersion": "0.6.114",
  "sourcePrompt": "Install editable UI Backlot source into a HyperFrames project; keep the copied HTML/CSS/JS editable.",
  "registryDependencies": [
    "mac-menu-bar",
    "claude-deck-chat-pane",
    "presentation-editor"
  ],
  "files": [
    {
      "path": "compositions/claude-presentation-chat-pane-workflow.html",
